# Integração com o backend (npm run dev no `web` + API em localhost:3000)
# Use `/api` para o proxy do Vite repassar ao backend — mesma origem = cookie HttpOnly do JWT funciona.
VITE_API_BASE_URL=/api
VITE_USE_MOCK=false
# true = envia header x-use-test-db (bootstrap de admin em ambiente de teste). false = integração “normal”.
VITE_USE_TEST_DB=false
