{
  "name": "prototipo-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:reset:all": "npm --prefix .. run db:reset:all",
    "test:unit": "vitest run",
    "test:e2e:run": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:compra:run": "cypress run --config video=true --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-feliz.cy.ts,cypress/e2e/fluxo/cliente-login-compra-falhas.cy.ts,cypress/e2e/shop/carrinho_checkout.cy.ts\"",
    "test:e2e:compra:chrome": "cypress run --config video=true --browser chrome --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-feliz.cy.ts,cypress/e2e/fluxo/cliente-login-compra-falhas.cy.ts,cypress/e2e/shop/carrinho_checkout.cy.ts\"",
    "test:e2e:compra:headed": "cypress run --config video=true --headed --browser chrome --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-feliz.cy.ts,cypress/e2e/fluxo/cliente-login-compra-falhas.cy.ts,cypress/e2e/shop/carrinho_checkout.cy.ts\"",
    "test:e2e:compra-feliz:run": "cypress run --config video=true --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-feliz.cy.ts\"",
    "test:e2e:compra-feliz:headed": "cypress run --config video=true --headed --browser chrome --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-feliz.cy.ts\"",
    "test:e2e:compra-falhas:run": "cypress run --config video=true --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-falhas.cy.ts\"",
    "test:e2e:compra-falhas:headed": "cypress run --config video=true --headed --browser chrome --env injectTestDbHeader=true --spec \"cypress/e2e/fluxo/cliente-login-compra-falhas.cy.ts\"",
    "test:e2e:carrinho:run": "cypress run --config video=true --env injectTestDbHeader=true --spec \"cypress/e2e/shop/carrinho_checkout.cy.ts\"",
    "test:e2e:carrinho:headed": "cypress run --config video=true --headed --browser chrome --env injectTestDbHeader=true --spec \"cypress/e2e/shop/carrinho_checkout.cy.ts\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cypress": "^15.10.0",
    "cypress-terminal-report": "^7.3.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
