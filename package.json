{
  "name": "prototipo-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:finalizacao-compra": "vitest run src/components/FinalizarCompra src/pages/Vendas/FinalizarCompra src/hooks/useGerenciadorLinhasPagamento.test.ts src/utils/finalizarCompraTotais.test.ts src/utils/finalizarCompraLiquidacaoPagamentos.test.ts",
    "test:unit:meus-pedidos": "vitest run src/pages/Vendas/MeusPedidos/CartaoResumoPedido.test.tsx src/hooks/useFiltrosMeusPedidos.test.ts",
    "test:unit:pagamentos": "vitest run src/components/FinalizarCompra/Pagamento/LinhaPagamento.test.tsx src/utils/cartaoValidacao.test.ts",
    "test:unit:carrinho": "vitest run src/components/Comum/ControlesCompra/controlesCompraCarrinho.test.ts",
    "test:dominio:checkout": "npm run test:unit:finalizacao-compra && npm run test:unit:pagamentos",
    "test:unit:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:e2e:cliente": "cypress run --spec \"cypress/e2e/user/cliente/**/*.cy.ts\"",
    "test:e2e:admin": "cypress run --spec \"cypress/e2e/user/admin/**/*.cy.ts\"",
    "test:e2e:shop": "cypress run --spec \"cypress/e2e/shop/**/*.cy.ts\"",
    "test:e2e:fluxo": "cypress run --spec \"cypress/e2e/fluxo/**/*.cy.ts\"",
    "test:e2e:ui-ux": "cypress run --spec \"cypress/e2e/ui-ux/**/*.cy.ts\"",
    "cypress:run": "cypress run",
    "cypress:run:cliente": "cypress run --spec \"cypress/e2e/user/cliente/**/*.cy.ts\"",
    "cypress:run:fluxo-login-compra": "cypress run --spec \"cypress/e2e/fluxo/cliente-login-compra-feliz.cy.ts\"",
    "cypress:run:fluxo-venda": "cypress run --spec \"cypress/e2e/fluxo/fluxo-venda.cy.ts\" --browser chrome",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.4",
    "cypress": "^15.10.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  }
}
